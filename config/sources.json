{
  "providers": [
    {
      "id": "openai",
      "name": "OpenAI",
      "rss": [
        "https://openai.com/news/rss.xml",
        "https://openai.com/blog/rss.xml"
      ],
      "api_endpoints": [
        {
          "name": "models_list",
          "url": "https://api.openai.com/v1/models",
          "auth_env": "OPENAI_OFFICIAL_API_KEY",
          "description": "OpenAI Models API - lists all available models"
        }
      ],
      "changelog_urls": [
        "https://developers.openai.com/api/docs/changelog",
        "https://openai.com/products/release-notes/"
      ],
      "news_pages": []
    },
    {
      "id": "anthropic",
      "name": "Anthropic",
      "rss": [],
      "api_endpoints": [
        {
          "name": "models_list",
          "url": "https://api.anthropic.com/v1/models",
          "auth_env": "ANTHROPIC_API_KEY",
          "description": "Anthropic Models API - lists all available models"
        }
      ],
      "changelog_urls": [
        "https://platform.claude.com/docs/en/release-notes/overview",
        "https://docs.anthropic.com/en/docs/about-claude/models"
      ],
      "news_pages": [
        {
          "url": "https://www.anthropic.com/news",
          "type": "newsroom",
          "description": "Anthropic official newsroom - model launches, partnerships, policy, research"
        }
      ]
    },
    {
      "id": "gemini",
      "name": "Google Gemini",
      "rss": [
        "https://blog.google/technology/ai/rss/"
      ],
      "api_endpoints": [
        {
          "name": "models_list",
          "url": "https://generativelanguage.googleapis.com/v1beta/models",
          "auth_env": "GOOGLE_AI_API_KEY",
          "description": "Google AI Models API - lists all available Gemini models"
        }
      ],
      "changelog_urls": [
        "https://ai.google.dev/gemini-api/docs/changelog"
      ],
      "news_pages": []
    }
  ],
  "third_party": [
    {
      "id": "artificial_analysis",
      "name": "Artificial Analysis",
      "type": "benchmark_tracker",
      "description": "Independent AI model benchmarking - Intelligence Index, speed, cost comparisons",
      "changelog_url": "https://artificialanalysis.ai/changelog",
      "filter_keywords": ["OpenAI", "GPT", "Anthropic", "Claude", "Google", "Gemini", "gpt-", "claude-", "gemini-"]
    }
  ],
  "settings": {
    "fetch_window_hours": 36,
    "similarity_threshold": 0.65
  }
}
